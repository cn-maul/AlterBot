# docker compose 环境变量
# 复制为 .env 并修改:
#   cp docker.env.example .env
#   docker compose up -d

# Go 版本
GO_VERSION=1.26-alpine

# Node 版本（构建前端）
NODE_VERSION=22-alpine

# Alpine 版本（运行镜像）
ALPINE_VERSION=3.21

# 映射端口
ALTERBOT_PORT=8080

# 时区
TZ=Asia/Shanghai

# Gin 模式 (release / debug / test)
GIN_MODE=release
